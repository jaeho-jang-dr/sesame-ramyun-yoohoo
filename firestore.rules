rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicit rule for 'apps' collection
    match /apps/{appId} {
      // Anyone can read apps
      allow read: if true;
      
      // Only admins can write (create/update/delete)
      // Checks if user is authenticated and is one of the admin emails
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'drjang00@gmail.com' || 
                    request.auth.token.email == '102030hohoho@gmail.com');
    }

    // Default rule for other collections (Development Mode)
    // Allows anyone to read/write until Feb 26, 2026.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 2, 26);
    }
  }
}
